<MudDialog>

    <DialogContent>
        <MudGrid Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="2">

            <!-- Image --> 
            <MudItem xs="12" sm="9" class="d-flex justify-center">
                <MudImage Src="icons/OpenRose_01.png" Width="72" Height="72" />
            </MudItem>

            <!-- Title -->
            <MudItem xs="12" sm="9" class="d-flex justify-center">
                <MudText Typo="Typo.h2" Align="Align.Center">
                    Welcome to <b>OpenRose</b>
                </MudText>
            </MudItem>

            <!-- Download link -->
            <MudItem xs="12" class="d-flex justify-center">
                <MudText Align="Align.Center" Color="Color.Primary">
                    || Just search for <b> OpenRose </b> online ||
                </MudText>
            </MudItem>

        </MudGrid>

    </DialogContent>
@*     <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Submit">Thanks!</MudButton>
    </DialogActions> *@
    
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
   
    private void Submit() => MudDialog.Close(DialogResult.Ok(true));
    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter") Submit();
    }
 }

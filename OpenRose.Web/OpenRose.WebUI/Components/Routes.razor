@using OpenRose.WebUI.Services
@using OpenRose.WebUI.Components.EventServices

@inject APIConfigurationService apiConfigService
@inject DataSourceStateService DataSourceStateServiceForRoutingGuard
@inject NavigationManager Nav

<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(Client._Imports).Assembly }"
        OnNavigateAsync="GuardNavigation"> 
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    private Task GuardNavigation(Microsoft.AspNetCore.Components.Routing.NavigationContext context)
    {

        Console.WriteLine($"[DEBUG] NOW IN GuardNavigation METHOD WITHIN Routes.razor ");
        // ========================================================================
        // ROUTING GUARD OVERVIEW
        // ------------------------------------------------------------------------
        // This method enforces navigation rules based on the current data source:
        //
        //   1. API SERVER MODE
        //        - Full access to all pages
        //        - Except when API is misconfigured or version‑mismatched
        //
        //   2. JSON MODES (Server JSON or Client JSON)
        //        - Application becomes READ‑ONLY
        //        - Only a small set of safe routes are allowed
        //        - All other routes redirect to /jsonviewer
        //
        //   3. UNKNOWN MODE
        //        - Fallback to home page
        //
        // This ensures the UI never enters an invalid or inconsistent state.
        // ========================================================================


        // ========================================================================
        // ALWAYS ALLOW HOME PAGE
        // ------------------------------------------------------------------------
        // The home page is always safe and acts as a neutral landing zone.
        // ========================================================================
        if (string.IsNullOrEmpty(context.Path) || context.Path == "/")
            return Task.CompletedTask;


        // ========================================================================
        // DETERMINE CURRENT DATA SOURCE MODE
        // ------------------------------------------------------------------------
        // The DataSourceStateService tracks whether we are in:
        //   - API mode
        //   - Server JSON mode
        //   - Client JSON mode
        //   - (Legacy) JsonFile mode
        //
        // We use the new helper properties:
        //   - IsApiMode
        //   - IsServerJsonMode
        //   - IsClientJsonMode
        //   - IsAnyJsonMode
        // ========================================================================
        var state = DataSourceStateServiceForRoutingGuard.CurrentDataSourceState;
        string path = context.Path.ToLowerInvariant().Trim('/');

        if (state.IsApiMode)
        {
            Console.WriteLine($"[Guard] ApiMode: IsConfigured={apiConfigService.IsOpenRoseAPIConfigured}, Mismatch='{apiConfigService.ApiVersionMismatchMessage}'");
            Console.WriteLine($"[Guard] JsonMode: path='{path}'");
        }

        // ============================================================
        // NONE MODE — Only allow Home ("/")
        // ============================================================
        // if (state.CurrentDataSourceType == DataSourceStateService.DataSourceType.None)
        // {
        //     if (path != "")
        //         Nav.NavigateTo("/", replace: true);

        //     return Task.CompletedTask;
        // }

        // ========================================================================
        // API SERVER MODE — FULL ACCESS (WITH HEALTH CHECKS)
        // ------------------------------------------------------------------------
        // In API mode, the user can navigate anywhere *as long as* the API is
        // configured correctly and the version matches.
        // ========================================================================
        // if (state.IsApiMode)
        // {
        //     // Block navigation if API is misconfigured or incompatible
        //     if (!ConfigService.IsOpenRoseAPIConfigured ||
        //         !string.IsNullOrEmpty(ConfigService.ApiVersionMismatchMessage))
        //     {
        //         Nav.NavigateTo("/");
        //         return Task.CompletedTask;
        //     }

        //     // API is healthy → allow navigation
        //     return Task.CompletedTask;
        // }



        // ========================================================================
        // JSON MODES — RESTRICTED READ‑ONLY NAVIGATION
        // ------------------------------------------------------------------------
        // Applies to BOTH:
        //   - Server JSON Mode (file loaded from server filesystem)
        //   - Client JSON Mode (file uploaded via browser)
        //
        // In JSON modes, the app is read‑only. Only a small set of routes are safe.
        // ========================================================================
        if (state.IsAnyJsonMode)
        {
            // Allowed routes in JSON mode:
            //   - ""           → home page
            //   - "jsonviewer" → main JSON viewer UI
            //   - "settings"   → user can switch modes
            bool isAllowed =
                path == "" ||
                path == "jsonviewer" ||
                path == "settings";

            Console.WriteLine($"[Guard] IsAnyJsonMode: true");
            Console.WriteLine($"[Guard] JsonMode: path='{path}'");

            if (!isAllowed)
            {
                // Block navigation to any route that requires API access or write access.
                // Redirect to the JSON viewer, which is the only safe place.
                Console.WriteLine($"[Guard] IsAnyJsonMode: Force navigating to -jsonviewer URL");
                Nav.NavigateTo("/jsonviewer", forceLoad: true);
                return Task.CompletedTask;
            }

            // Allowed route → proceed
            return Task.CompletedTask;
        }


        // ========================================================================
        // UNKNOWN MODE — FAIL SAFE
        // ------------------------------------------------------------------------
        // If the data source state is somehow invalid, redirect to home.
        // ========================================================================
        // // Nav.NavigateTo("/");
        return Task.CompletedTask;
    }

}
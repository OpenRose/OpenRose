<style>
	.product-title-link {
		transition: font-size 0.2s ease, transform 0.2s;
		font-weight: 500;
		color: #fff !important;
		display: inline-block;
	}

		.product-title-link:hover {
			transform: scale(1.08);
			cursor: pointer;
			color: #fff !important;
		}

	/* STYLE FOR JSON FILE DATA SOURCE MODE */
	/* When connected to JSON file, title bar is Purpul instead of default Blue */
	.app-bar-json-file-mode {
		background-color: #85059C !important; /* Purpul color for offline mode */
	}

	.app-bar-api-mode {
		/* Default Blue color for API mode - MudBlazor's default AppBar color */
	}

	.app-bar-none-mode {
		background-color: #ADD8E6 !important; /* Light blue */
	}


	/* STYLE FOR FOOTER SHOWING FILE PATH */
	.file-path-footer {
		background-color: #f5f5f5;
		border-top: 1px solid #e0e0e0;
		padding: 8px 16px;
		font-size: 12px;
		color: #666;
	}

	.file-path-footer-text {
		display: inline-block;
		margin-right: 10px;
	}

	.file-path-footer-button {
		cursor: pointer;
		/* color: #1976d2; */
		margin-left: 8px;
		text-decoration: underline;
	}

</style>


@using MudBlazor;

<MudTooltip Text="Show Hierarchy Tree">
    <MudIcon Icon="@Icon"
             Size="Size.Small"
             Class="mouse-pointer-icon"
             Style="cursor:pointer"
             @onclick="OpenDialog" />
</MudTooltip>

@code {
    [Parameter] public Guid RecordId { get; set; }
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.AccountTree;

    [Inject] IDialogService DialogService { get; set; }

    private async Task OpenDialog()
    {
        var parameters = new DialogParameters
        {
            ["RecordId"] = RecordId
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            CloseOnEscapeKey = true,
            Position = DialogPosition.Center,
            FullWidth = true
        };

        await DialogService.ShowAsync<HierarchyTreeDialog>("Parent Hierarchy Tree", parameters, options);
    }
}

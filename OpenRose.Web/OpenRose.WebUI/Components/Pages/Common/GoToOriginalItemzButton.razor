@using OpenRose.WebUI.Client.Services.BaselineItemz
@using OpenRose.WebUI.Components.Dialogs
@using OpenRose.WebUI.Components.FindServices
@inject IBaselineItemzService BaselineItemzService
@inject IFindProjectAndBaselineIdsByBaselineItemzIdService FindBaselineParents
@inject IFindProjectOfItemzId FindProjectOfItemzId
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<MudTooltip Text="Go To Origin" Placement="Placement.Top">
    <MudIcon Icon="@Icon"
                Size="@Size.Small"
                Class="mouse-pointer-icon"
                Style="cursor:pointer"
                @onclick="OnClick" />
</MudTooltip>



@code {
    [Parameter] public Guid BaselineItemzId { get; set; }
    [Parameter] public bool UseTreeView { get; set; } = false; // Default is Details View
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.SportsBaseball;

    private async Task ShowError(string message)
    {
        var parameters = new DialogParameters { ["Message"] = message };
        var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogRef = await DialogService.ShowAsync<ErrorDialog>("Error", parameters, options);
        await dialogRef.Result;
    }

    private async Task OnClick()
    {
        // 1. Load baseline Itemz
        var baselineItemz =
            await BaselineItemzService.__Single_BaselineItemz_By_GUID_ID__Async(BaselineItemzId);

        if (baselineItemz == null)
        {
            await ShowError($"Baseline Itemz with ID {BaselineItemzId} could not be found!");
            return;
        }

        // 2. Ensure it links to an original Itemz
        if (baselineItemz.ItemzId == Guid.Empty)
        {
            await ShowError("This Baseline Itemz is not linked to an original Itemz. It may have been deleted.");
            return;
        }

        // 3. Get baseline project
        var (baselineProjectId, _) =
            await FindBaselineParents.GetProjectAndBaselineId(BaselineItemzId);

        if (baselineProjectId == Guid.Empty)
        {
            await ShowError("Could not determine the Project for this Baseline Itemz.");
            return;
        }

        // 4. Get original Itemz project
        var originalProjectId =
            await FindProjectOfItemzId.getProjectIdOfItemzId(baselineItemz.ItemzId);

        if (originalProjectId == Guid.Empty)
        {
            await ShowError("The original Itemz could not be found. It may have been deleted or removed from the repository.");
            return;
        }

        // 5. Confirm if projects differ
        if (baselineProjectId != originalProjectId)
        {
            var dialogPara = new DialogParameters
            {
                ["DialogMessage"] = "The original Itemz is now present in a different Project. Switch Project view?"
            };

            var dialogRef = await DialogService.ShowAsync<OkCancelDialog>("Confirm", dialogPara);
            var result = await dialogRef.Result;

            if (result.Canceled)
                return;
        }

        // 6. Navigate
        var baseUrl = $"/goto/{baselineItemz.ItemzId}";
        var url = UseTreeView
            ? NavManager.ToAbsoluteUri($"{baseUrl}?view=TreeView").ToString()
            : NavManager.ToAbsoluteUri(baseUrl).ToString();

        await JS.InvokeVoidAsync("openInNewTab", url);
    }
}

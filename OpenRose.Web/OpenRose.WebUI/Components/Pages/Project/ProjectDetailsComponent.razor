    private async Task ConfirmNavigation(LocationChangingContext context)
    {
        // Use FormStateService instead of local flag
        bool canLeave = await FormStateService.ConfirmDiscardChangesAsync(ProjectId);

        if (!canLeave)
        {
            // User chose "Stay" → cancel navigation
            context.PreventNavigation();
        }
        else
        {
            // User confirmed discard → clear dirty state
            FormStateService.SetDirty(ProjectId, false);
        }
    }


@using OpenRose.WebUI.Client.Services.Hierarchy
@using OpenRose.WebUI.Client.SharedModels
@using MudBlazor
@using OpenRose.WebUI.Components.Dialogs
@inject IHierarchyService HierarchyService
@* @inject ISnackbar Snackbar *@
@inject IDialogService DialogService

@if (IsLoading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (HierarchyData != null)
{
    @if (errors.Length > 0)
    {
        <MudPaper Class="pa-4 mud-height-full mud-width-full">
            <MudText Typo="Typo.subtitle2" Color="@Color.Error">@($"Validation Errors ({errors.Length})")</MudText>
            @foreach (var error in errors)
            {
                <MudText Color="@Color.Error">@error</MudText>
            }
        </MudPaper>
    }
      <MudStack Row="true" Spacing="2" Class="mt-2">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary"
                       Disabled="@(disableUpdateItemzDetailsButton)"
                       OnClick="SaveEstimation">
                Save
            </MudButton>

            <MudButton Variant="Variant.Filled" 
                       Color="Color.Warning"
                       Disabled="@(disableUpdateItemzDetailsButton)"
                       OnClick="CancelEdit">
                Cancel
            </MudButton>
        </MudStack>
    <MudForm Model="@HierarchyData" @ref="form" @bind-IsValid="@success" @bind-Errors="@errors" FieldChanged="formFieldChanged">

    <MudGrid Class="mt-2">
        <MudItem xs="12" md="4">
            <MudTextField T="string"
                            Label="Estimation Unit"
                            @bind-Value="HierarchyData.EstimationUnit"
                            Placeholder="Not Available"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            ReadOnly="true"
                            Disabled="true" />
        </MudItem>

        <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Own Estimation"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Dense="true"
                              @bind-Value="OwnEstimationText"
                              Immediate="true" />
        </MudItem>

        <MudItem xs="12" md="4">
            <MudTextField T="decimal"
                          Label="Rolled-up Estimation"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Dense="true"
                          Value="@HierarchyData.RolledUpEstimation"
                          ReadOnly="true"
                          Disabled="true"/>
        </MudItem>
    </MudGrid>
    </MudForm>
}
else
{
    <MudText Color="Color.Warning">No hierarchy and estimation data available</MudText>
}

@code {
    [Parameter] public Guid ItemzId { get; set; }
    [Parameter] public string? RecordType { get; set; }

    private HierarchyIdRecordDetailsDTO? HierarchyData;
    private string OwnEstimationText = "";

    private bool IsLoading;

    //MudForm related fields
    bool success = true;
    string[] errors = { };
    bool disableUpdateItemzDetailsButton = true;
    MudForm form;

    protected override async Task OnParametersSetAsync()
    {
        await LoadHierarchyData();
    }

    private async Task LoadHierarchyData()
    {
        IsLoading = true;
        try
        {
            HierarchyData = await HierarchyService.__Get_Hierarchy_Record_With_Estimations_Async__(ItemzId);
            OwnEstimationText = (HierarchyData?.OwnEstimation)?.ToString() ?? "";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveEstimation()
    {
       // decimal? parsed = null;

        if (!decimal.TryParse(OwnEstimationText, out var parsedValue))
        {
            var parameters = new DialogParameters { ["Message"] = "Please enter a valid decimal number for estimation." };
            var options = new DialogOptions
            {
                CloseButton = false,
                MaxWidth = MaxWidth.Small,
                FullWidth = true
            };

            // Use ShowAsync instead of Show
            await DialogService.ShowAsync<ErrorDialog>("Invalid Input", parameters, options);

            return; // invalid input, stop saving
        }

        decimal? parsed = parsedValue;

        try
        {
            var updateDTO = new UpdateHierarchyEstimationDTO
            {
                RecordId = ItemzId,
                OwnEstimation = parsed
            };

            var result = await HierarchyService.__Update_Hierarchy_Estimation_Async__(ItemzId, updateDTO);

            if (result)
            {
                await LoadHierarchyData();
                disableUpdateItemzDetailsButton = true;
            }
            else
            {
                await DialogService.ShowMessageBox(
                    "ERROR",
                    markupMessage: new MarkupString($"<p style=\"color: red;\"> Failed to update estimation </p>"),
                    yesText: "OK");
            }
        }
        catch (Exception ex)
        {
            await DialogService.ShowMessageBox(
                "ERROR",
                markupMessage: new MarkupString($"<p style=\"color: red;\"> {ex.Message} </p>"),
                yesText: "OK");
        }
    }



    private void CancelEdit()
    {
        OwnEstimationText = (HierarchyData?.OwnEstimation)?.ToString() ?? "";
        disableUpdateItemzDetailsButton = true;
    }


    private async Task formFieldChanged()
    {
        if (form != null)
        {
            await form.Validate();
            if (form.IsValid)
            {
                disableUpdateItemzDetailsButton = false;
            }
            else
            {
                disableUpdateItemzDetailsButton = true;
            }
        }

    }
}
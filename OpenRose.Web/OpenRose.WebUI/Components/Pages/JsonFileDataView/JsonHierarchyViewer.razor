    protected override void OnInitialized()
    {
        JsonService.OnJsonChanged += HandleStateChangedAsync;
        DataSourceState.OnDataSourceChanged += HandleStateChangedAsync;

        StateHasChanged();
    }

    // private void HandleStateChanged()
    // {
    //     InvokeAsync(StateHasChanged);
    // }

    private async Task HandleStateChangedAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        JsonService.OnJsonChanged -= HandleStateChangedAsync;
        DataSourceState.OnDataSourceChanged -= HandleStateChangedAsync;

    }

    private void SwitchToApi()
    {
        DataSourceState.SwitchToApiDataSource();
        //Nav.NavigateTo("/", forceLoad: true);
        Nav.NavigateTo("/");
    }

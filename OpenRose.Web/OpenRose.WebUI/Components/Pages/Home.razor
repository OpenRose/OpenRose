@page "/"
@using OpenRose.WebUI.Components.EventServices
@using OpenRose.WebUI.Configuration
@using OpenRose.WebUI.Services

@implements IDisposable

<PageTitle>OpenRose</PageTitle>

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
    <MudImage Src="icons/OpenRose_01.png" Width="72" Height="72" />
    <MudText Typo="Typo.h2" Align="Align.Left">
        Welcome to <b>OpenRose</b>
    </MudText>
</MudStack>

@if (StartupCapabilities.ApiAvailable)
{
    @if (!string.IsNullOrEmpty(apiConfigService.ApiVersionMismatchMessage))
    {
        <br />
        <MudText Typo="Typo.h5" Align="Align.Left" Color="Color.Error">
            @apiConfigService.ApiVersionMismatchMessage
        </MudText>

        <!-- Optional: manual reconnect button -->
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@_isReconnectDisabled"
                   OnClick="Reconnect">
            @(_isReconnectDisabled ? "Please wait..." : "Reconnect to API")
        </MudButton>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <br />
        <MudText Typo="Typo.h5" Align="Align.Left" Color="Color.Error">
            @_errorMessage
        </MudText>
        <MudText Typo="Typo.inherit" Align="Align.Left" Color="Color.Error">
            Environment Name: @Env.EnvironmentName
        </MudText>
        <br />
        <MudChip T="string" Icon="@Icons.Material.Filled.Numbers" Size="Size.Small" Color="Color.Success">
            Version - @version
        </MudChip>
    }
}

@code {
    [Inject] private APIConfigurationService apiConfigService { get; set; } = default!;
    [Inject] private IWebHostEnvironment Env { get; set; } = default!;
    [Inject] private AssemblyInfoService AssemblyInfo { get; set; } = default!;
    [Inject] private ApiVersionChecker VersionChecker { get; set; } = default!;
    [Inject] private StartupCapabilitiesService StartupCapabilities { get; set; } = default!;
    [Inject] private DataSourceStateService DataSourceStateService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    //[Inject] private IServiceProvider Services { get; set; } = default!;


    // EXPLANATION ::
    // In the past we did use _errorMessage to show that API server was not available but then we 
    // started supporting Enhanced StartUp Mode and we allow admins to configure OpenRose without 
    // connecting to API layer. So we decided not to show any more errorMessages when API layer is
    // not configured. Anyways, we decided to leave this variable here just in case if we need to 
    // use it for any other purpose in the future. 

    private string _errorMessage = string.Empty;
    private string version = string.Empty;
    private bool _isReconnectDisabled = false;
    //private ApiVersionChecker? VersionChecker;

    private static bool _redirectedOnce = false;

    protected override void OnInitialized()
    {

        // Redirect ONLY when the application starts in Server JSON mode
        if (DataSourceStateService.CurrentDataSourceState.IsServerJsonMode)
        {
            Navigation.NavigateTo("/serverdatafiles", replace: true);
            return; // Prevent further initialization
        }

        version = AssemblyInfo.GetAssemblyVersion();

        // Console.WriteLine("Home subscribing directly to ConfigService.OnChange");
        apiConfigService.OnChange -= HandleConfigChanged; // ensure no duplicate
        apiConfigService.OnChange += HandleConfigChanged;
    }

    private void HandleConfigChanged()
    {
        //Console.WriteLine("Home component received change event");
        InvokeAsync(StateHasChanged);
    }

    private async Task Reconnect()
    {
        _isReconnectDisabled = true;
        @if (StartupCapabilities.ApiAvailable)
        {
            var ok = await VersionChecker.CheckApiVersionAsync();
            // StateHasChanged(); // Blazor does this automatically after event handlers

            if (ok)
            {
                _errorMessage = string.Empty;   // <-- FIX
            }
        }

        // Wait few seconds before re-enabling
        await Task.Delay(TimeSpan.FromSeconds(3));
        _isReconnectDisabled = false;
        // StateHasChanged();
    }

    public void Dispose()
    {
        // Console.WriteLine("Home unsubscribing from ConfigService.OnChange");
        apiConfigService.OnChange -= HandleConfigChanged;
    }

}

@using OpenRose.WebUI.Client.Services.BaselineHierarchy
@using OpenRose.WebUI.Client.Services.BaselineItemzTypes
@using OpenRose.WebUI.Client.Services.Hierarchy
@using OpenRose.WebUI.Client.SharedModels
@using OpenRose.WebUI.Components.Dialogs
@using OpenRose.WebUI.Components.EventServices
@using OpenRose.WebUI.Components.Pages.Common
@using System.Globalization
@inject NavigationManager NavManager
@inject BaselineTreeNodeItemzSelectionService BaselineItemzSelectionService
@inject IDialogService DialogService
@inject IJSRuntime JS

<MudPaper Class="pa-4 mb-3 ml-1 align-start d-flex" Style="width: auto" Outlined="false">
	<MudText Typo="Typo.h6" Align="Align.Left">Baseline ItemzType</MudText>
</MudPaper>

<MudGrid>
	@if (initializingPage)
	{
		<MudPaper Height="calc(100vh - 100px);" Width="100%">
			<MudOverlay Visible="@initializingPage" DarkBackground="true" Absolute="true">
				<MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Inherit">Loading ...</MudText>
				<br />
				<MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
			</MudOverlay>
		</MudPaper>
	}
	else
	{
 		<MudItem xs="12" sm="12">
			<MudCard style="background-color : #FABBBB;" >
				<MudCardContent>
				<MudItem Class="align-start d-flex" Style="width: auto" Outlined="false">
					<MudGrid>
						<MudItem xs="12" sm="12" md="7" lg="7">
							<MudText Typo="Typo.h5" Align="Align.Left"><strong>@singleIBaselineItemzType.Name </strong></MudText>
						</MudItem>
						<MudItem xs="12" sm="12" md="5" lg="5">
							<MudStack Row="true" Spacing="2" AlignItems="AlignItems.End" Justify="Justify.FlexEnd" Class="w-100">
										<MudButton OnClick="async _ => await openBaselineItemzTypeDetailsView(BaselineItemzTypeId.ToString())" Variant="@Variant.Filled" Size="@Size.Medium" Color="@Color.Success" Target="_blank"> Details View </MudButton>
							</MudStack>
						</MudItem>
					</MudGrid>
				</MudItem>
				</MudCardContent>
			</MudCard>
			<MudCard>
				<MudCardContent>

					<MudStack Row="true" Spacing="2" StretchItems="StretchItems.None" AlignItems="AlignItems.Start" Class="w-100">
						<MudStack Row="true" Spacing="2">
							<MudText><strong>ID          : </strong></MudText>
							<CopyableText TextToCopy="@singleIBaselineItemzType.Id.ToString()" DisplayLength="8" />
							<MudTooltip Text="Show in Tree View" Placement="Placement.Top">
								<MudIcon Icon="@Icons.Material.Filled.Park" Size="Size.Small" Class="mouse-pointer-icon" @onclick="findAndShowInTreeView" />
							</MudTooltip>
							<MudTooltip Text="GoTo Origin" Placement="Placement.Top">
								<MudIcon Icon="@Icons.Material.Filled.SportsBaseball"
										 Size="Size.Small"
										 Class="mouse-pointer-icon"
										 @onclick="async _ => await gotoOriginalRecord(singleIBaselineItemzType.Id.ToString())" />
							</MudTooltip>
						</MudStack>
						<MudText><strong> || Status      : </strong> @singleIBaselineItemzType.Status</MudText>
						<MudText><strong> || Is System?  : </strong> @(singleIBaselineItemzType.IsSystem ? "Yes" : "No")</MudText>
					</MudStack>

@* 					<MudStack Row="true" Spacing="2">
						<MudText><strong>ID           : </strong> </MudText>
						<CopyableText TextToCopy="@singleIBaselineItemzType.Id.ToString()" />
						<MudTooltip Text="Show in Tree View">
						<MudIcon Icon="@Icons.Material.Filled.Park" Size="Size.Small" Class="mouse-pointer-icon" @onclick="findAndShowInTreeView" />
						</MudTooltip>
					</MudStack>
					<MudText><strong>Status       : </strong> @singleIBaselineItemzType.Status</MudText>
					<MudText><strong>Is System?   : </strong> @(singleIBaselineItemzType.IsSystem ? "Yes" : "No") </MudText>
					<MudText><strong>Created Date : </strong> @singleIBaselineItemzType.CreatedDate.ToString("dd MMM yyyy HH:mm:ss", CultureInfo.CurrentCulture)</MudText> *@
					<MudText><strong>Description : </strong></MudText>
					<br />
					<div class="custom-markdown-editor">
						<MudPaper Class="pa-4 mb-5">
							@if (!string.IsNullOrEmpty(singleIBaselineItemzType.Description))
							{
								<div class="markdown-body">@((MarkupString)convertedMarkdown)</div>
							}
						</MudPaper>
					</div>
				</MudCardContent>
			</MudCard>
		</MudItem>
	}
</MudGrid>
@code {
    [Parameter]
    public Guid BaselineItemzTypeId { get; set; }

    [Inject]
    public IBaselineItemzTypesService baselineItemzTypesService { get; set; }

    [Inject]
    public IBaselineHierarchyService baselineHierarchyService { get; set; }

    [Inject]
    public IHierarchyService hierarchyService { get; set; }

    public GetBaselineItemzTypeDTO singleIBaselineItemzType { get; set; } = new();
    public bool initializingPage { get; set; } = true;

    private MarkupString convertedMarkdown;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            initializingPage = true;
            StateHasChanged();
            //await Task.Delay(300);
            singleIBaselineItemzType = await baselineItemzTypesService.__Single_BaselineItemzType_By_GUID_ID__Async(BaselineItemzTypeId);

            // TODO :: THROW EXCEPTION IF BASELINE ITEMTYPE IS NOT FOUND!

            initializingPage = false;

            await ConvertMarkdownToHtml(singleIBaselineItemzType.Description);

            StateHasChanged();
        }
    }
    private void findAndShowInTreeView()
    {
        BaselineItemzSelectionService.ScrollToTreeViewNode(BaselineItemzTypeId);
    }

    public async Task openBaselineItemzTypeDetailsView(string Id)
    {
        var url = $"/baselineItemzType/{Id}";
        await JS.InvokeVoidAsync("openInNewTab", url);
    }

    private async Task ConvertMarkdownToHtml(string markdown)
    {
        if (!string.IsNullOrEmpty(markdown))
        {
            var html = await JS.InvokeAsync<string>("markdownToHtml", markdown);
            convertedMarkdown = (MarkupString)html;
            StateHasChanged();

            // Apply fullscreen styles
            // await Task.Delay(1000);
            // await JS.InvokeVoidAsync("applyMarkdownEditorFullscreenStyles");
        }
    }

    #region "Go To Original Record Logic"

    // TODO :: This regional code has been duplicated in other BaselineItemzType components as well.


    private async Task OpenExceptionDialogAsync(string exceptionMessage)
    {
        var parameters = new DialogParameters { ["Message"] = exceptionMessage };
        var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogRef = await DialogService.ShowAsync<ErrorDialog>("Error", parameters, options);
        await dialogRef.Result;
    }

    public async Task gotoOriginalRecord(string id)
    {

        Guid tempProjectIdThroughBaselineItemzType = Guid.Empty;
        Guid tempProjectIdThroughOriginalItemzType = Guid.Empty;

        // Validate GUID
        if (!Guid.TryParse(id, out var baselineItemzTypeGuid))
        {
            await OpenExceptionDialogAsync($"Invalid GUID: {id}");
            return;
        }

        // Fetch baseline
        var tempBaselineItemzType = await baselineItemzTypesService.__Single_BaselineItemzType_By_GUID_ID__Async(baselineItemzTypeGuid);
        if (tempBaselineItemzType == null)
        {
            await OpenExceptionDialogAsync($"Baseline ItemzType with ID {id} could not be found!");
            return;
        }

        // Verify that original ItemzType is present in the hierarchy table.
        var tempBaselineItemzTypeHierarchyRecord = await baselineHierarchyService.__Get_BaselineHierarchy_Record_Details_By_GUID__Async(baselineItemzTypeGuid);

        if (tempBaselineItemzTypeHierarchyRecord != null
                && tempBaselineItemzTypeHierarchyRecord.ParentRecordId != Guid.Empty)
        {
            var tempParentHierarchyRecordDetails = await baselineHierarchyService
                                                .__Get_BaselineHierarchy_Record_Details_By_GUID__Async(
                                                    tempBaselineItemzTypeHierarchyRecord.ParentRecordId);

            tempProjectIdThroughBaselineItemzType = tempParentHierarchyRecordDetails.ParentRecordId;
        }
        else
        {
            await OpenExceptionDialogAsync($"The Baseline ItemzType with ID {id} is not properly linked in the hierarchy. Cannot navigate to original record.");
            return;
        }


        // Find Original ItemzType record in hierarchy using BaselineItemzType's linked ItemzTypeId

        var foundOriginalitemzTypeHierarchyRecord = await hierarchyService
                                                    .__Get_Hierarchy_Record_Details_By_GUID__Async(
                                                        tempBaselineItemzType.ItemzTypeId);

        if (foundOriginalitemzTypeHierarchyRecord != null
                && foundOriginalitemzTypeHierarchyRecord.ParentRecordId != Guid.Empty)
        {
            var tempOriginalParentHierarchyRecordDetails = await hierarchyService
                                                    .__Get_Hierarchy_Record_Details_By_GUID__Async(
                                                        foundOriginalitemzTypeHierarchyRecord.ParentRecordId);

            tempProjectIdThroughOriginalItemzType = tempOriginalParentHierarchyRecordDetails.RecordId;
        }
        else
        {
            await OpenExceptionDialogAsync($"The original ItemzType record linked to this Baseline ItemzType could not be found. Cannot navigate to original record.");
            return;
        }


        if (tempProjectIdThroughBaselineItemzType == Guid.Empty 
            || tempProjectIdThroughOriginalItemzType == Guid.Empty)
        {
            await OpenExceptionDialogAsync($"Could not determine the project for the Baseline ItemzType or its linked original ItemzType. Cannot navigate to original record.");
            return;
        }

        if (tempProjectIdThroughBaselineItemzType != tempProjectIdThroughOriginalItemzType)
        {
            var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, Position = DialogPosition.Center };
            var dialogPara = new DialogParameters();
            dialogPara.Add("DialogMessage", $"Original ItemzType has been moved to another Project. Do you want to switch Project view? tempProjectIdThroughBaselineItemzType is {tempProjectIdThroughBaselineItemzType} and  tempProjectIdThroughOriginalItemzType is {tempProjectIdThroughOriginalItemzType}");
            var dialogref = await DialogService.ShowAsync<OkCancelDialog>("CONFIRM", parameters: dialogPara, options);
            var dialogresult = await dialogref.Result;
			if ((dialogresult!.Canceled))
			{
                return;
            }
		}

		// Build URL using NavigationManager (safer & future‑proof)
        var url = NavManager.ToAbsoluteUri($"/goto/{tempBaselineItemzType.ItemzTypeId}?view=TreeView").ToString(); // TODO :: Use constant for TreeView

		// Open in new tab
		await JS.InvokeVoidAsync("openInNewTab", url);
	}

    #endregion
}

